# Ghostty configuration for macOS
# https://ghostty.org/docs/config

# Updates
auto-update = download
auto-update-channel = stable

# Theme and appearance
theme = GitHub Dark Colorblind
background = #0d1117
background-blur = 20
background-opacity = 0.9
foreground = #c9d1d9
window-theme = dark

# Font
font-family = MonaspaceNeon-Regular
font-family-bold = MonaspaceNeon-Medium
font-family-italic = MonaspaceNeon-MediumItalic
font-family-bold-italic = MonaspaceNeon-BoldItalic
font-size = 12
font-thicken = true

# Cursor
cursor-color = #58a6ff
cursor-text = #98e6ff
cursor-style-blink = true
custom-shader = shaders/smear_cursor.glsl

# Selection
selection-background = #c9d1d9
selection-foreground = #0d1117

# Window padding
window-padding-x = 5
window-padding-y = 5
window-padding-balance = true

# macOS window and titlebar
#
# "transparent" keeps an integrated macOS appearance while avoiding
# Ghostty's custom titlebar-tabs layout.
macos-titlebar-style = transparent
macos-titlebar-proxy-icon = hidden
macos-option-as-alt = true

# macOS application icon
macos-icon = xray
macos-icon-frame = chrome
macos-icon-ghost-color = #6A0CF6
macos-icon-screen-color = #2B076E

# Clipboard and mouse
clipboard-read = allow
mouse-hide-while-typing = true
mouse-shift-capture = true

# Terminal palette
palette = 0=#484f58
palette = 1=#ec8e2c
palette = 2=#58a6ff
palette = 3=#d29922
palette = 4=#58a6ff
palette = 5=#bc8cff
palette = 6=#39c5cf
palette = 7=#b1bac4
palette = 8=#6e7681
palette = 9=#fdac54
palette = 10=#79c0ff
palette = 11=#e3b341
palette = 12=#79c0ff
palette = 13=#d2a8ff
palette = 14=#56d4dd
palette = 15=#ffffff
