{
  "$schema": "https://opencode.ai/config.json",
  "logLevel": "WARN",
  "autoupdate": false,
  "share": "disabled",
  "enabled_providers": [
    "opencode-go",
    "google",
    "openai"
  ],
  "instructions": [],
  "permission": {
    "websearch": "allow",
    "codesearch": "allow",
    "webfetch": "allow",
    "skill": "allow",
    "github": "ask"
  },
  "experimental": {
    "openTelemetry": false
  },
  "agent": {
    "build": {
      "mode": "primary",
      "model": "openai/gpt-5.5",
      "permission": {
        "read": "allow",
        "edit": {
          "*": "allow"
        },
        "skill": "allow",
        "task": "allow"
      }
    },
    "fast": {
      "mode": "primary",
      "model": "openai/gpt-5.5",
      "description": "Fast reasoning with limited iterations",
      "prompt": "You are a quick thinker. Solve problems with minimal steps.",
      "steps": 5
    },
    "explore": {
      "mode": "subagent",
      "model": "openai/gpt-5.4-mini"
    },
    "summary": {
      "mode": "subagent",
      "model": "openai/gpt-5.4-mini"
    },
    "title": {
      "mode": "subagent",
      "model": "openai/gpt-5.4-mini"
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ],
      "enabled": true
    },
    "linear": {
      "command": [
        "npx",
        "-y",
        "mcp-remote",
        "https://mcp.linear.app/mcp"
      ],
      "type": "local"
    }
  },
  "model": "openai/gpt-5.5",
  "small_model": "openai/gpt-5.4-mini"
}
