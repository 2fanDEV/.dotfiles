{
  "$schema": "https://opencode.ai/config.json",
  "disabled_providers": ["opencode"],
  "logLevel": "WARN",
  "autoupdate": false,
  "share": "disabled",
  "enabled_providers": ["github-copilot", "opencode-go", "google"],
  "instructions": [],
  "permission": {
    "websearch": "allow",
    "codesearch": "allow",
    "webfetch": "allow",
    "skill": "allow",
    "github": "ask"
  },
  "experimental": {
    "openTelemetry": false
  },
  "agent": {
    "plan": {
      "mode": "primary",
      "model": "github-copilot/claude-opus-4.6",
      "temperature": 0.5,
      "permission": {
        "edit": {
          "*": "deny"
        },
        "task": "allow"
      }
    },
    "build": {
      "mode": "primary",
      "temperature": 0.0,
      "model": "opencode-go/minimax-m2.7",
      "permission": {
        "edit": {
          "*": "allow"
        },
        "skill": "allow",
        "task": "allow"
      }
    },
    "fast": {
      "mode": "primary",
      "model": "github-copilot/gpt-5.4",
      "description": "Fast reasoning with limited iterations",
      "prompt": "You are a quick thinker. Solve problems with minimal steps.",
      "steps": 5
    },
    "explore": {
      "mode": "subagent",
      "model": "github-copilot/claude-haiku-4.5"
    },
		"compaction": {
			 "mode": "subagent",
			 "model": "github-copilot/claude-sonnet-4.6"
		},
		"summary": {
			"mode": "subagent",
			"model": "github-copilot/claude-sonnet-4.6"
		},
		"title": {
			"mode": "subagent",
			"model": "github-copilot/claude-haiku-4.5"
		}
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": true
    },
    "linear": {
      "command": ["npx", "-y", "mcp-remote", "https://mcp.linear.app/mcp"],
      "type": "local"
    }
  },
  "model": "github-copilot/gpt-5.4",
  "small_model": "github-copilot/gpt-5.4-mini",
  "plugin": ["@tarquinen/opencode-dcp@3.1.4"]
}
