{
  "$schema": "https://opencode.ai/config.json",
  "disabled_providers": ["opencode"],
  "$schema": "https://opencode.ai/config.json",
  "logLevel": "WARN",
  "autoupdate": false,
  "share": "disabled",
  "plugin": [],
  "enabled_providers": ["github-copilot", "openai", "google"],
  "instructions": [],
  "mcp": {},
  "permission": {
    "websearch": "ask",
    "codesearch": "ask",
    "webfetch": "ask",
    "skill": "ask",
    "github": "ask"
  },
  "experimental": {
    "openTelemetry": false
  },
  "agent": {
    "plan": {
      "mode": "primary",
      "model": "openai/gpt-5.3-codex",
      "temperature": 0.3,
      "permission": {
        "edit": {
          "*": "ask"
        }
      }
    },
    "build": {
      "mode": "primary",
      "temperature": 0.5,
      "model": "openai/gpt-5.3-codex",
      "permission": {
        "edit": {
          "*": "allow"
        },
        "skill": "allow",
        "task": "allow"
      }
    },
    "fast": {
      "mode": "primary",
      "model": "openai/gpt-5.3-codex",
      "description": "Fast reasoning with limited iterations",
      "prompt": "You are a quick thinker. Solve problems with minimal steps.",
      "steps": 5
    },
    "explore": {
      "mode": "subagent",
      "model": "openai/claude-haiku-4.5"
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": true
    },
    "linear": {
      "command": ["npx", "-y", "mcp-remote", "https://mcp.linear.app/mcp"],
      "type": "local"
    }
  },
  "model": "openai/gpt-5.4",
	"small_model": "openai/gpt-5-mini",
  "plugin": []
}
